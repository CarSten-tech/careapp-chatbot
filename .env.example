DATABASE_URL=postgresql+asyncpg://careapp:careapp_dev@localhost:5432/careapp_dev
TEST_DATABASE_URL=postgresql+asyncpg://careapp:careapp_dev@localhost:5433/careapp_test

# LLM-Anbieter — einer der folgenden Keys muss gesetzt sein (oder DEV_LLM=fake).
# Priorität: NVIDIA_API_KEY > ANTHROPIC_API_KEY

# Option A: NVIDIA NIM (Kimi K2.6 und andere Modelle)
NVIDIA_API_KEY=nvapi-...
NVIDIA_MODEL_ID=moonshotai/kimi-k2.6
# NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1   # Default — nur ändern wenn nötig

# Option B: Anthropic Claude
ANTHROPIC_API_KEY=sk-ant-...

# FastAPI-Laufzeit
CAREAPP_DEV_AUTH=true             # Pilot-AuthContext ohne JWT (nur lokale Entwicklung!)
DEV_LLM=fake                      # FakeLLMClient statt AnthropicLLMClient
CAREAPP_ADMIN_TOKEN=sicher-langes-passwort-hier-eintragen  # Admin-Backend-Zugang
CAREAPP_GRAPH_VERSION=graph-v1
CAREAPP_PROMPT_VERSION=prompts-v1
CAREAPP_MODEL_VERSION=models-v1
CAREAPP_ALLOWED_ORIGINS=http://localhost:3000

# Next.js (apps/web/.env.local)
# FASTAPI_URL=http://localhost:8000
